    "typecheck:watch": "tsc -b --watch",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@react-navigation/drawer": "^7.9.9",
    "@react-navigation/native": "^7.2.2",
    "@types/react": "^19.2.14",
