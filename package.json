  "description": "Turn any WordPress site into a real native app. Open source. Token auth. No WebViews.",
  "license": "GPL-2.0-or-later",
  "author": "Chris Huber <chubes@extrachill.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chubes4/wp-native.git"
